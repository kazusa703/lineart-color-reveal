# Line art provider: "local" (client-side Sobel) or "replicate" (server-side AI)
NEXT_PUBLIC_LINEART_PROVIDER=local

# Replicate API token (required when NEXT_PUBLIC_LINEART_PROVIDER=replicate)
REPLICATE_API_TOKEN=

# Replicate model: default is DexiNed edge detection
REPLICATE_LINEART_MODEL=jagvar/dexined
# Alternative: HED edge detection
REPLICATE_LINEART_MODEL_HED=cjwbw/hed

# Replicate polling/timeout
REPLICATE_POLL_INTERVAL_MS=500
REPLICATE_TIMEOUT_MS=60000

# Upstash Redis for persistent cache (optional; falls back to in-memory only)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Cache TTL for line art results (seconds, default 24h)
LINEART_CACHE_TTL_SEC=86400

# Max input dimension for server-side line art (pixels)
LINEART_MAX_DIM=1536

# Rate limit: max requests per minute per client fingerprint
RATE_LIMIT_PER_MINUTE=10
EXPORT_RATE_LIMIT_PER_MINUTE=20

# Stripe (credit system)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_CREDITS_10=
STRIPE_PRICE_CREDITS_30=
STRIPE_PRICE_CREDITS_100=

# Public app URL (for Stripe redirect)
PUBLIC_APP_URL=http://localhost:3000

# Beta watermark: set to "false" to disable globally (default: true)
BETA_WATERMARK_ENABLED=true
